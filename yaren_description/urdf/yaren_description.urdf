<?xml version="1.0" encoding="utf-8"?>
<robot name="yaren_description">

  <material name="MediumYellow">
    <color rgba="0.9 0.7 0.0 1.0"/>
  </material>

  <material name="Black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>
  
  <link name="world"/>

  <joint name="base_joint" type="fixed">
      <parent link="world"/>
      <child link="base_link"/>
      <origin rpy="0 0 0.0" xyz="0.0 0.0 0.064"/>
  </joint>

  <link name="base_link">
    <inertial>
      <origin xyz="-0.011194 -0.036845 0.215654" rpy="0 0 0" />
      <mass value="1.3678" />
      <inertia ixx="0.00319" ixy="0.0" ixz="0.0" iyy="0.00601" iyz="0.0" izz="0.00319" />
    </inertial>
    <visual>
      <origin xyz="0.01 0.2105 0.0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://yaren_description/meshes/base_link.STL" />
      </geometry>
      <material name="Black"/>
    </visual>
    <collision>
      <origin xyz="0.01 0.2105 0.0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://yaren_description/meshes/base_link.STL" />
      </geometry>
    </collision>
  </link>

  <joint name="joint_1" type="revolute">
    <origin xyz="0.0 0.0 0.020523" rpy="1.5708 0 1.6008" />
    <parent link="base_link" />
    <child link="link_1" />
    <axis xyz="0 1 0" />
    <limit lower="-10.0" upper="10.0" effort="300" velocity="3" />
  </joint>

  <link name="link_1">
