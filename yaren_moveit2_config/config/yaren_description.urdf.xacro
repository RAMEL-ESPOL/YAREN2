<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="yaren_description">
  <xacro:arg name="initial_positions_file" default="initial_positions.yaml" />

  <xacro:include filename="$(find yaren_description)/urdf/yaren_description.urdf" />

  <xacro:include filename="yaren_description_moveit.ros2_control.xacro" />

  <yaren_description_moveit_ros2_control
      name="FakeSystem"
      initial_positions_file="$(arg initial_positions_file)"/>
</robot>